# Root `.env` — loaded automatically by `docker compose` from this directory.
# Copy to `.env` and fill in. Used to pass public Supabase vars into the dashboard image/build.

# --- Supabase (required for dashboard auth) — Project Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Internal collector auth (required) ---
# Shared secret between the Go gateway and the OTel Collector. The collector's
# bearertokenauth extension rejects every OTLP request that doesn't present
# `Authorization: Bearer <this value>`; the gateway sets that header internally
# after stripping the SDK client's API-key auth. Both services refuse to start
# with an empty value (#25 — defense-in-depth on the collector socket).
#
# Generate a fresh value with `openssl rand -hex 32` and paste here.
COLLECTOR_AUTH_TOKEN=replace_me_with_openssl_rand_hex_32

# --- Dev-default credentials (override for any non-local deploy) ---
# These ride on the `${VAR:-default}` substitutions in `docker-compose.yaml`.
# The defaults below match what the local stack ships with, so an empty
# `.env` Just Works for `docker compose up` on a laptop. For staging/prod,
# either set them explicitly here or pass `--env-file .env.production` —
# see "Production deployment" in the root README.
#
# #31 — moved from compose-hardcoded into substitution so a single source
# of truth (this file) can be diffed against the production env.

# ClickHouse — read by the `clickhouse` server, the OTel Collector exporter,
# and the dashboard's `lib/clickhouse.ts`. The dashboard's client hard-fails
# at module load if either USER or PASSWORD is missing (no compiled-in
# fallback as of #31), so leaving these blank breaks dashboard startup.
CLICKHOUSE_USER=otel                  # dev default — change for any non-local deploy
CLICKHOUSE_PASSWORD=otelpass          # dev default — change for any non-local deploy

# Postgres — backs the dashboard's Prisma schema (organizations, api_keys,
# monitors). Two consumers downstream:
#   • `dashboard` container reads DATABASE_URL directly (Prisma).
#   • `gateway` container reads DATABASE_URL for the API-key hydrate (#26).
# When you change USER/PASSWORD/DB you must also update DATABASE_URL — the
# DSN is intentionally separate so an external Postgres (Supabase, RDS) can
# be wired without rewriting the docker-compose service.
POSTGRES_USER=postgres                # dev default — change for any non-local deploy
POSTGRES_PASSWORD=postgres            # dev default — change for any non-local deploy
POSTGRES_DB=ward                      # dev default — fine to keep
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ward

# Grafana — purely a dev convenience. The local stack admin/admin would be
# an immediate foothold in any deploy that exposes :3000 to the internet.
GF_SECURITY_ADMIN_USER=admin          # dev default — change for any non-local deploy
GF_SECURITY_ADMIN_PASSWORD=admin      # dev default — change for any non-local deploy

# Redis — gateway authenticates with this; dashboard's `lib/redis.ts` and the
# gateway's `cmd/gateway/main.go` BOTH refuse to start with an empty value
# (#34 — fail-closed so an operator misconfig that leaves the redis task
# itself running with `--requirepass ""` doesn't silently downgrade the
# stack to anonymous Redis). The redis service runs with `--requirepass
# $REDIS_PASSWORD`, so a fresh value here protects every consumer.
#
# Generate with `openssl rand -hex 32`. If you also bake the password into
# a custom REDIS_URL like `redis://:secret@host:6379` make it url-safe
# (alphanumeric + `_-` only) so you don't have to think about percent-
# encoding `:`, `@`, `/`. The dashboard's client passes the password via
# the ioredis `password:` option independently of REDIS_URL, so a plain
# `redis://host:6379` URL with a separate `REDIS_PASSWORD` is fine.
REDIS_PASSWORD=devredispass           # dev default — change for any non-local deploy
