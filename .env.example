# Root `.env` — loaded automatically by `docker compose` from this directory.
# Copy to `.env` and fill in. Used to pass public Supabase vars into the dashboard image/build.

# --- Supabase (required for dashboard auth) — Project Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Internal collector auth (required) ---
# Shared secret between the Go gateway and the OTel Collector. The collector's
# bearertokenauth extension rejects every OTLP request that doesn't present
# `Authorization: Bearer <this value>`; the gateway sets that header internally
# after stripping the SDK client's API-key auth. Both services refuse to start
# with an empty value (#25 — defense-in-depth on the collector socket).
#
# Generate a fresh value with `openssl rand -hex 32` and paste here.
COLLECTOR_AUTH_TOKEN=replace_me_with_openssl_rand_hex_32
