generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id         String      @id @default(uuid())
  name       String
  slug       String      @unique
  tenantId   String      @unique @map("tenant_id")
  tier       String      @default("free")
  rateLimit  Int         @default(10000) @map("rate_limit")
  createdAt  DateTime    @default(now()) @map("created_at")
  members    OrgMember[]
  apiKeys    ApiKey[]
  monitors   Monitor[]

  @@map("organizations")
}

model OrgMember {
  id         String       @id @default(uuid())
  orgId      String       @map("org_id")
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  authUserId String       @map("auth_user_id")
  role       String       @default("member")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@unique([orgId, authUserId])
  @@map("org_members")
}

model ApiKey {
  id         String       @id @default(uuid())
  orgId      String       @map("org_id")
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name       String
  keyPrefix  String       @map("key_prefix")
  keyHash    String       @unique @map("key_hash")
  active     Boolean      @default(true)
  lastUsedAt DateTime?    @map("last_used_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@map("api_keys")
}

// Monitor â€” alerting rule on cost / latency_p95 / error_rate. State machine
// is owned by the cron worker (#16). Field shape mirrors `MonitorInput` /
// `Monitor` in `dashboard/src/lib/monitors.ts` so frontend's hand-rolled
// validateMonitorInput can be swapped for `MonitorInputSchema.parse()` body-only
// in #15. Source-of-truth design: `.agents/monitors-design.md` Â§2.
//
// `metric` / `comparator` / `windowMinutes` are deliberately NOT Prisma enums
// â€” zod at the action layer is the source of truth, and enum migrations are
// painful when V1.1 widens the allowlist (e.g. add `latency_p99`, `8h` window).
model Monitor {
  id              String         @id @default(uuid())
  orgId           String         @map("org_id")
  org             Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  metric          String         // 'cost' | 'latency_p95' | 'error_rate'
  comparator      String         // 'gt' | 'gte' | 'lt' | 'lte'
  threshold       Float
  windowMinutes   Int            @map("window_minutes") // 5 | 15 | 60 | 360 | 1440
  environment     String?        // null = all envs
  model           String?        // null = all models
  enabled         Boolean        @default(true)
  state           String         @default("ok") // 'ok' | 'firing'
  lastEvaluatedAt DateTime?      @map("last_evaluated_at")
  lastValue       Float?         @map("last_value")
  createdBy       String?        @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  triggers        MonitorTrigger[]

  // Hot read path: banner's count(orgId, state='firing') runs on every
  // dashboard render plus 30s F10 polls. List page status filter benefits too.
  @@index([orgId, state])
  @@map("monitors")
}

// MonitorTrigger â€” one row per fire/resolve transition. Worker writes the row
// on okâ†’firing; updates `resolvedAt` on firingâ†’ok. Threshold + comparator are
// snapshotted at fire time so the detail page's history table is stable even
// if the parent monitor is later edited.
model MonitorTrigger {
  id           String   @id @default(uuid())
  monitorId    String   @map("monitor_id")
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  firedAt      DateTime @default(now()) @map("fired_at")
  resolvedAt   DateTime? @map("resolved_at")
  triggerValue Float    @map("trigger_value")
  threshold    Float
  comparator   String

  @@index([monitorId, firedAt])
  @@map("monitor_triggers")
}
