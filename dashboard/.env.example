# Dashboard environment template. Copy to `.env` and fill in. The host's
# `.env` is gitignored (root `.gitignore`).

# --- Supabase (required for dashboard auth) — Project Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Postgres (Prisma) — host port 5434 maps to postgres:5432 in docker-compose ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/anchor

# --- ClickHouse (read path for /overview, /traces) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=otel
CLICKHOUSE_PASSWORD=otelpass

# --- Redis (API key cache; gateway and dashboard sync writes here) ---
REDIS_URL=redis://localhost:6379

# --- Monitor evaluation cron worker (#16) ---
# Shared secret between the cron trigger (Vercel Cron in prod, the local
# `pnpm worker:monitors` script in dev) and the route handler at
# `/api/cron/evaluate-monitors`. Required — the route returns 503 if unset.
# Pick a long, opaque value for prod deploys.
CRON_SECRET=replace-me-with-a-long-random-string
